# Server
PORT=5002
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/paper-trading
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/paper-trading?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production_at_least_32_chars
JWT_EXPIRES_IN=7d

# Initial virtual balance for new users
INITIAL_BALANCE=100000

# CoinGecko API (free tier, no key required for /coins/markets)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Cache TTL in seconds
PRICE_CACHE_TTL=60

# CORS
CLIENT_URL=http://localhost:5173
