# Backend production environment template.
# Copy to .env.production (or inject via your platform's secret manager).

# Server
PORT=5002
NODE_ENV=production

# Database — REQUIRED in production. MongoDB Atlas or self-hosted MongoDB 6+.
MONGODB_URI=mongodb://mongo:27017/paper-trading

# JWT — generate with: `openssl rand -hex 48`
JWT_SECRET=please_replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Initial virtual cash given to every new account
INITIAL_BALANCE=100000

# CoinGecko (free tier is fine; private endpoint not required)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
PRICE_CACHE_TTL=60

# Frontend origin used for CORS. With nginx reverse-proxy this is irrelevant;
# set the public URL when the API is consumed cross-origin.
CLIENT_URL=https://your-frontend-domain.example.com

# WebSocket price stream broadcast interval (milliseconds)
PRICE_STREAM_INTERVAL_MS=10000
