flowchart TD
    Start([Baslangic]) --> Login{Giris yapildi mi?}
    Login -->|Hayir| Register[Kayit Ol / Giris]
    Register --> Auth[JWT Token Al]
    Auth --> Dashboard
    Login -->|Evet| Dashboard[Dashboard'u Goruntule]

    Dashboard --> Browse[Piyasayi Tara]
    Browse --> Pick{Coin sec}
    Pick --> Detail[Coin detayi - grafik]
    Detail --> Decide{Islem yapilsin mi?}

    Decide -->|Hayir| Browse
    Decide -->|Evet| ChooseSide{Yon sec}

    ChooseSide -->|BUY| ChooseType1{Tip sec}
    ChooseSide -->|SELL| ChooseType2{Tip sec}

    ChooseType1 -->|MARKET| MarketBuy[Market Order BUY]
    ChooseType1 -->|LIMIT| LimitBuy[Limit Order BUY]
    ChooseType2 -->|MARKET| MarketSell[Market Order SELL]
    ChooseType2 -->|LIMIT| LimitSell[Limit Order SELL]

    MarketBuy --> ValidateBuy{Bakiye yeterli mi?}
    MarketSell --> ValidateSell{Varlik yeterli mi?}

    ValidateBuy -->|Hayir| ErrorBuy[Hata - Yetersiz nakit]
    ValidateBuy -->|Evet| ExecBuy[Anlik fiyatla AL]
    ValidateSell -->|Hayir| ErrorSell[Hata - Yetersiz varlik]
    ValidateSell -->|Evet| ExecSell[Anlik fiyatla SAT]

    LimitBuy --> StorePending[PENDING olarak kaydet]
    LimitSell --> StorePending
    StorePending --> Wait[Worker arka planda bekliyor]
    Wait --> CheckPrice{Hedef fiyata ulasildi mi?}
    CheckPrice -->|Hayir| Wait
    CheckPrice -->|Evet| ExecLimit[Otomatik gerceklestir]

    ExecBuy --> UpdatePF[Portfoyu guncelle]
    ExecSell --> UpdatePF
    ExecLimit --> UpdatePF
    UpdatePF --> RecordTx[Islem kaydet]
    RecordTx --> ShowResult[Sonucu goster]

    ShowResult --> ViewPortfolio{Devam?}
    ErrorBuy --> ViewPortfolio
    ErrorSell --> ViewPortfolio
    ViewPortfolio -->|Yeni islem| Browse
    ViewPortfolio -->|Cikis| End([Bitis])

    style Start fill:#10B981,stroke:#10B981,color:#000
    style End fill:#EF4444,stroke:#EF4444,color:#fff
    style ExecBuy fill:#10B981,stroke:#10B981,color:#000
    style ExecSell fill:#10B981,stroke:#10B981,color:#000
    style ExecLimit fill:#10B981,stroke:#10B981,color:#000
    style ErrorBuy fill:#EF4444,stroke:#EF4444,color:#fff
    style ErrorSell fill:#EF4444,stroke:#EF4444,color:#fff
